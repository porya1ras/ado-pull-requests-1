{
    "name": "ado-pull-requests",
    "displayName": "Azure DevOps Pull Requests",
    "description": "List and manage Azure DevOps Pull Requests",
    "version": "0.0.1",
    "repository": {
        "type": "git",
        "url": "https://github.com/Careberry/ComparePRs"
    },
    "engines": {
        "vscode": "^1.80.0"
    },
    "categories": [
        "Other"
    ],
    "activationEvents": [],
    "main": "./dist/extension.js",
    "contributes": {
        "commands": [
            {
                "command": "adoPr.signIn",
                "title": "ADO: Sign In"
            },
            {
                "command": "adoPr.selectRepo",
                "title": "ADO: Select Repository"
            },
            {
                "command": "adoPr.refresh",
                "title": "Refresh Pull Requests",
                "icon": "$(refresh)"
            },
            {
                "command": "adoPr.viewFileDiff",
                "title": "View Diff"
            },
            {
                "command": "adoPr.copilotReview",
                "title": "ADO: Send PR to Copilot Review",
                "icon": "$(comment-discussion)"
            },
            {
                "command": "adoPr.openPr",
                "title": "Open PR in Browser",
                "icon": "$(link-external)"
            }
        ],
        "menus": {
            "view/title": [
                {
                    "command": "adoPr.refresh",
                    "when": "view == ado-pr-explorer",
                    "group": "navigation"
                },
                {
                    "command": "adoPr.selectRepo",
                    "when": "view == ado-pr-explorer",
                    "group": "navigation"
                }
            ],
            "view/item/context": [
                {
                    "command": "adoPr.copilotReview",
                    "when": "viewItem == pullRequest",
                    "group": "inline"
                },
                {
                    "command": "adoPr.openPr",
                    "when": "viewItem == pullRequest",
                    "group": "inline"
                }
            ]
        },
        "viewsContainers": {
            "activitybar": [
                {
                    "id": "ado-pr-explorer",
                    "title": "ADO Pull Requests",
                    "icon": "$(git-pull-request)"
                }
            ]
        },
        "views": {
            "ado-pr-explorer": [
                {
                    "id": "ado-pr-explorer",
                    "name": "Pull Requests"
                }
            ]
        }
    },
    "scripts": {
        "vscode:prepublish": "npm run package",
        "compile": "webpack",
        "watch": "webpack --watch",
        "package": "webpack --mode production --devtool hidden-source-map",
        "compile-tests": "tsc -p . --outDir out",
        "watch-tests": "tsc -p . -w --outDir out",
        "pretest": "npm run compile-tests && npm run compile && npm run lint",
        "lint": "eslint src --ext ts",
        "test": "node ./out/test/runTest.js"
    },
    "devDependencies": {
        "@types/vscode": "^1.80.0",
        "@types/glob": "^8.1.0",
        "@types/mocha": "^10.0.1",
        "@types/node": "20.2.5",
        "@typescript-eslint/eslint-plugin": "^5.59.8",
        "@typescript-eslint/parser": "^5.59.8",
        "eslint": "^8.41.0",
        "glob": "^8.1.0",
        "mocha": "^10.2.0",
        "typescript": "^5.1.3",
        "ts-loader": "^9.4.3",
        "webpack": "^5.85.0",
        "webpack-cli": "^5.1.1"
    },
    "dependencies": {
        "azure-devops-node-api": "^12.0.0"
    }
}