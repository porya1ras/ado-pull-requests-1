{
    "name": "ado-pull-requests1",
    "displayName": "Azure DevOps Pull Requests Reviewer",
    "description": "List and manage Azure DevOps Pull Requests",
    "version": "1.1.1",
    "publisher": "Porya0Ras",
    "icon": "assets/icon.png",
    "repository": {
        "type": "git",
        "url": "https://github.com/porya1ras/ado-pull-requests-1"
    },
    "engines": {
        "vscode": "^1.109.0"
    },
    "categories": [
        "Other"
    ],
    "keywords": [
        "ado",
        "azure devops",
        "code review",
        "comments preview",
        "pull request",
        "ai review"
    ],
    "activationEvents": [],
    "main": "./dist/extension.js",
    "contributes": {
        "commands": [
            {
                "command": "adoPr.signIn",
                "title": "ADO: Sign In"
            },
            {
                "command": "adoPr.selectRepo",
                "title": "ADO: Select Repository"
            },
            {
                "command": "adoPr.signOut",
                "title": "Connected (Click to Sign Out)",
                "icon": "$(plug)"
            },
            {
                "command": "adoPr.refreshLoading",
                "title": "Connecting to DevOps...",
                "icon": "$(sync~spin)"
            },
            {
                "command": "adoPr.signIn",
                "title": "Disconnected (Click to Sign In)",
                "icon": "$(debug-disconnect)"
            },
            {
                "command": "adoPr.viewFileDiff",
                "title": "View Diff"
            },
            {
                "command": "adoPr.copilotReview",
                "title": "ADO: Send PR to AI Review",
                "icon": "$(comment-discussion)"
            },
            {
                "command": "adoPr.dbPerformanceReview",
                "title": "ADO: DB Performance Review",
                "icon": "$(database)"
            },
            {
                "command": "adoPr.uxMessageReview",
                "title": "ADO: UX Message Review",
                "icon": "$(feedback)"
            },
            {
                "command": "adoPr.openPr",
                "title": "Open PR in Browser",
                "icon": "$(link-external)"
            }
        ],
        "menus": {
            "view/title": [
                {
                    "command": "adoPr.signOut",
                    "when": "view == ado-pr-explorer && adoPr.isConnected && !adoPr.isConnecting",
                    "group": "navigation"
                },
                {
                    "command": "adoPr.refreshLoading",
                    "when": "view == ado-pr-explorer && adoPr.isConnecting",
                    "group": "navigation"
                },
                {
                    "command": "adoPr.signIn",
                    "when": "view == ado-pr-explorer && !adoPr.isConnected && !adoPr.isConnecting",
                    "group": "navigation"
                }
            ],
            "view/item/context": [
                {
                    "command": "adoPr.copilotReview",
                    "when": "viewItem == pullRequest",
                    "group": "inline"
                },
                {
                    "command": "adoPr.dbPerformanceReview",
                    "when": "viewItem == pullRequest",
                    "group": "inline"
                },
                {
                    "command": "adoPr.uxMessageReview",
                    "when": "viewItem == pullRequest",
                    "group": "inline"
                },
                {
                    "command": "adoPr.openPr",
                    "when": "viewItem == pullRequest",
                    "group": "inline"
                }
            ]
        },
        "viewsContainers": {
            "activitybar": [
                {
                    "id": "ado-pr-explorer",
                    "title": "Azure DevOps",
                    "icon": "$(git-pull-request)"
                }
            ]
        },
        "views": {
            "ado-pr-explorer": [
                {
                    "id": "ado-pr-explorer",
                    "name": "Explorer",
                    "type": "webview",
                    "icon": "$(git-pull-request)"
                }
            ]
        }
    },
    "scripts": {
        "vscode:prepublish": "npm run package",
        "compile": "webpack",
        "watch": "webpack --watch",
        "package": "webpack --mode production --devtool hidden-source-map",
        "compile-tests": "tsc -p . --outDir out",
        "watch-tests": "tsc -p . -w --outDir out",
        "pretest": "npm run compile-tests && npm run compile && npm run lint",
        "lint": "eslint src --ext ts",
        "test": "node ./out/test/runTest.js"
    },
    "devDependencies": {
        "@types/glob": "^8.1.0",
        "@types/mocha": "^10.0.1",
        "@types/node": "20.2.5",
        "@types/vscode": "^1.109.0",
        "@typescript-eslint/eslint-plugin": "^5.59.8",
        "@typescript-eslint/parser": "^5.59.8",
        "eslint": "^8.41.0",
        "glob": "^8.1.0",
        "mocha": "^10.2.0",
        "ts-loader": "^9.4.3",
        "typescript": "^5.1.3",
        "webpack": "^5.85.0",
        "webpack-cli": "^5.1.1"
    },
    "dependencies": {
        "azure-devops-node-api": "^12.0.0"
    }
}